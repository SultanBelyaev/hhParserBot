# База данных SQLite (путь относительно корня проекта)
DATABASE_URL=sqlite:///./hh_parser.db

# Файл сессии браузера (cookies HH.ru)
SESSION_FILE=data/session.json

# Headless-режим браузера (false для отладки)
HEADLESS=true

# Максимум скроллов при загрузке выдачи
SCROLL_MAX=30

# Пауза между скроллами (мс)
SCROLL_PAUSE_MS=500

# Запас вакансий при скролле (1.5 = грузим на 50% больше лимита)
SCROLL_BUFFER_FACTOR=1.5

# Задержка между откликами (мс). Меньше = быстрее, но риск блокировки
APPLY_DELAY_MS=700

# Таймаут ожидания ответа модалки (сек)
APPLY_POLL_TIMEOUT_SEC=5.0

# Скрывать пропущенные вакансии (true = медленнее, чище выдача)
HIDE_SKIPPED_VACANCIES=false

# Блокировать картинки/шрифты для ускорения загрузки
BLOCK_MEDIA=true

# Telegram-бот
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Ваш Telegram user ID (узнать: /start у бота). Можно несколько через запятую.
TELEGRAM_ALLOWED_USER_IDS=

# Если бот не подключается (Timed out) — VPN или локальный прокси:
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
TELEGRAM_PROXY_URL=
TELEGRAM_CONNECT_TIMEOUT=30
TELEGRAM_READ_TIMEOUT=30

# GitHub — для scripts/git_push.py (токен НЕ коммитить!)
# GITHUB_TOKEN=ghp_xxxxxxxx
# GITHUB_REPO=ваш_логин/hh-parser
